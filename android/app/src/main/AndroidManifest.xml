<?xml version="1.0" encoding="utf-8"?>
<!--
  This is the AndroidManifest for the IG Downloader Flutter app.
  After running `flutter create .` this file will be auto-generated.
  MERGE the <intent-filter> and <uses-permission> blocks below into
  the generated android/app/src/main/AndroidManifest.xml.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ─────────────────────────────────────────────────── -->
    <!-- Internet — fetch IG pages and download media -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Write to external storage (Android 9 and below) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>

    <!-- Read media (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <!-- Foreground service so downloads keep running when backgrounded.
         FOREGROUND_SERVICE + POST_NOTIFICATIONS are merged in by the
         flutter_foreground_task plugin; the typed permission below is required
         on Android 14+ (API 34) to match the dataSync service type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>

    <!-- ── Package visibility (Android 11+) ───────────────────────────────
         url_launcher must be able to resolve the Instagram app's custom
         scheme to deep-link straight onto a post (instagram://media?id=…).
         Without this <queries> entry the launch silently fails on API 30+. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="instagram"/>
        </intent>
    </queries>

    <application
        android:label="IG Downloader"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true">

        <!--
          Recents de-duplication for share targets:
          - launchMode singleTask  → only ever one MainActivity instance; a new
            share is delivered to the existing one via onNewIntent.
          - documentLaunchMode never → overrides FLAG_ACTIVITY_NEW_DOCUMENT /
            FLAG_ACTIVITY_MULTIPLE_TASK that Instagram's share sheet sets, which
            is what was spawning a fresh Recents card per share. With "never",
            every share stays in the one task → a single Recents entry.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:documentLaunchMode="never"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Standard app launch intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!--
              ─────────────────────────────────────────────────────────────
              SHARE INTENT — receives URLs from Instagram (and any other app)
              When the user taps Share → IG Downloader in Instagram, Android
              sends an ACTION_SEND intent with mimeType text/plain containing
              the post URL.
              ─────────────────────────────────────────────────────────────
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>

        </activity>

        <!-- Foreground service that keeps the download queue alive in the
             background (flutter_foreground_task). dataSync type matches the
             FOREGROUND_SERVICE_DATA_SYNC permission declared above. -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false"
            android:stopWithTask="false"/>

        <!-- Don't delete the FlutterActivity meta-data -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

    </application>
</manifest>
